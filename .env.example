# Copy to .env.local and fill in. All values are SERVER-ONLY — never prefix with NEXT_PUBLIC_.

# ElevenLabs server SDK auth (lib/elevenlabs.ts auto-reads this).
ELEVENLABS_API_KEY=

# The dashboard-configured ConvAI agent id (Agents section / conversation-token mint).
AGENT_ID=

# Anthropic (Claude) key for summary + script passes (lib/llm.ts).
ANTHROPIC_API_KEY=